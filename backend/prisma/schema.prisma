// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}
// al parecer ya no se necesita el datasource, se puede configurar con la url del .env para usarla en prisma.config.ts
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")  // marca error porque segun "ya no se maneja este parametro", se tiene que mantener para el correcto funcionamiento de prisma.
}

// aqui de definen las tablas, campos y relaciones
// modelo de ejemplo, modificar segun se necesite

model tUsuarios {
  id_usuario Int      @id @default(autoincrement())
  nombre     String
  correo     String    @unique
  contraseña String
  edad       Int
  peso       Float
  estatura   Float
  objetivo   String?
  // relaciones
  tPlanAlim        tPlanAlim[]
  tRegistroDiario  tRegistroDiario[]
  @@map("tUsuarios")
}

model tPlanAlim {
  id_plan             Int       @id @default(autoincrement())
  id_usuario          Int
  calorias_diarias    Int
  fecha_inicio        DateTime
  fecha_fin           DateTime

  // Relaciones
  usuario             tUsuarios @relation(fields: [id_usuario], references: [id_usuario])

  @@map("tPlanAlim")
}

model recetas {
  id_receta             Int              @id @default(autoincrement())
  nombre                String
  descripcion           String
  calorias              Int
  tiempo_preparacion    Int
  imagen_url            String?

  // Relaciones
  recetaAlimentos       tRecetaAlim[]

  @@map("recetas")
}

model tAlimentos {
  id_alimento        Int              @id @default(autoincrement())
  nombre             String
  calorias           Float
  proteinas          Float
  carbohidratos      Float
  grasas             Float

  // Relaciones
  recetaAlimentos    tRecetaAlim[]

  @@map("tAlimentos")
}

model tRecetaAlim {
  id_receta      Int
  id_alimento    Int
  cantidad       Float

  // Relaciones
  receta         recetas      @relation(fields: [id_receta], references: [id_receta])
  alimento       tAlimentos   @relation(fields: [id_alimento], references: [id_alimento])

  // PK compuesta
  @@id([id_receta, id_alimento])

  @@map("tRecetaAlim")
}

model tRegistroDiario {
  id_registro            Int         @id @default(autoincrement())
  id_usuario             Int
  fecha                  DateTime
  calorias_consumidas    Int

  // Relaciones
  usuario                tUsuarios   @relation(fields: [id_usuario], references: [id_usuario])

  @@map("tRegistroDiario")
}